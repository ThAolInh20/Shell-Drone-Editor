{
  "name": "shell-drone-animation",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "main": "src/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.shelldrone.editor",
    "productName": "ShellDroneEditor",
    "copyright": "Copyright © 2026 ThaoLinn20",
    "directories": {
      "output": "dist-electron"
    },
    "asar": true,
    "files": [
      "dist/**/*",
      "src/electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "public/icon2.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Shell Drone Editor"
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.4",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "three": "^0.183.2"
  }
}